#include <stdio.h>
#include <string.h>
 
int main() {
  	char s1[50] = "Hello", s2[50] = "World", s3[100];
  	printf("25331A05G3\n");
  	printf("Length of s1: %lu\n", strlen(s1));
  	strcpy(s3, s1);
  	printf("Copied string: %s\n", s3);
  	strcat(s1, s2);
  	printf("Concatenated: %s\n", s1);
  	printf("Compare s1,s2: %d\n", strcmp("Hello","Hello"));
  	return 0;
}
